{
  "cleanUrls": true,
  "crons": [
    { "path": "/api/nurture", "schedule": "0 10 * * *" },
    { "path": "/api/outreach?auto=1", "schedule": "0 15 * * *" }
  ],
  "rewrites": [
    { "source": "/api/sample", "destination": "/api/sample" },
    { "source": "/api/auth", "destination": "/api/auth" },
    { "source": "/api/stats", "destination": "/api/stats" },
    { "source": "/api/contacts/:id", "destination": "/api/contacts?id=:id" },
    { "source": "/api/contacts", "destination": "/api/contacts" },
    { "source": "/api/outreach", "destination": "/api/outreach" },
    { "source": "/api/nurture", "destination": "/api/nurture" },
    { "source": "/api/submissions", "destination": "/api/stats?view=submissions" },
    { "source": "/api/track/open", "destination": "/api/track/open" },
    { "source": "/api/track/click", "destination": "/api/track/click" },
    { "source": "/api/chat", "destination": "/api/chat" },
    { "source": "/api/subscriber", "destination": "/api/subscriber" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    },
    {
      "source": "/api/track/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate" }
      ]
    }
  ]
}
